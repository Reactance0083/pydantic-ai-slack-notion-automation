# Slack App credentials
# Find: api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# Find: api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# Notion integration credentials
# Find: notion.so/my-integrations → New integration → Internal Integration Token
NOTION_API_KEY=secret_your-notion-key-here

# Find: Open your Notion database → Share → Copy link → extract the ID from URL
# URL format: notion.so/workspace/DATABASE_ID?v=VIEW_ID
NOTION_DATABASE_ID=your-database-id-here

# Anthropic API key (for pydantic-ai classifier)
# Find: console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
